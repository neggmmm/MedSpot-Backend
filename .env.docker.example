PORT=8000
FRONTEND_URI=https://your-frontend-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
# IMPORTANT: HOST must be 'db' (the docker-compose service name), NOT localhost
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me-strong-password
DATABASE_NAME=nest_market
DATABASE_SSL=false
# Leave DATABASE_URL empty when using split values above
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# IMPORTANT: HOST must be 'redis' (the docker-compose service name), NOT localhost
REDIS_HOST=redis
REDIS_PORT=6379
# Set a strong password — it's used by both redis-server and your app
REDIS_PASSWORD=change-me-strong-redis-password

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_KEY=change-me
AWS_REGION=eu-north-1
AWS_S3_BUCKET=change-me
AWS_S3_PRODUCTS_PREFIX=products

# ── Paymob ────────────────────────────────────────────────────────────────────
PAYMOB_INTEGRATION_ID=change-me
PAYMOB_IFRAME_ID=change-me
PAYMOB_API_URI=https://accept.paymob.com/api
PAYMOB_API_KEY=change-me
PAYMOB_HMAC_SECRET=

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=change-me
MAIL_PASS=change-me
MAIL_FROM=change-me
